#!/usr/bin/env bash
set -euo pipefail

real_codex="${CODEX_REAL_BIN:-/opt/homebrew/bin/codex}"

if [[ "${HOME:-}" == *"/.oryn-lab" && "${PWD:-}" == "$HOME"* ]]; then
  config="$HOME/.codex/config.toml"
  mkdir -p "$(dirname "$config")"
  if ! grep -Fq "[projects.\"$PWD\"]" "$config" 2>/dev/null; then
    {
      [[ -s "$config" ]] && printf '\n'
      printf '[projects."%s"]\ntrust_level = "trusted"\n' "$PWD"
    } >> "$config"
  fi
fi

args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --approval-mode)
      mode="${2:-}"
      shift 2 || true
      if [[ "$mode" == "full-auto" ]]; then
        args+=(--ask-for-approval never --sandbox danger-full-access)
      elif [[ -n "$mode" ]]; then
        args+=(--ask-for-approval "$mode")
      fi
      ;;
    --approval-mode=full-auto)
      args+=(--ask-for-approval never --sandbox danger-full-access)
      shift
      ;;
    --approval-mode=*)
      args+=(--ask-for-approval "${1#--approval-mode=}")
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

exec "$real_codex" "${args[@]}"
